{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "types": [
      "node"
