{
  "name": "butler-to-itch",
  "version": "1.3.1",
  "private": true,
  "description": "Setup renpy action",
  "author": "Ayowel",
  "license": "MIT",
  "main": "dist/setup/index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "ncc build -o dist/setup src/butler-manage.ts",
    "format": "prettier --write \"{,!(node_modules)/**/}*.ts\"",
    "format-check": "prettier --check \"{,!(node_modules)/**/}*.ts\"",
    "lint": "echo \"Fake command that does nothing. It is used in reusable workflows\"",
    "prerelease": "npm run-script build",
    "release": "git add -f dist/setup/index.js dist/setup/package.json",
    "test": "tsc --noEmit && node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayowel/butler-to-itch.git"
  },
  "keywords": [
    "actions",
    "renpy",
    "setup"
  ],
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/tool-cache": "^4.0.0",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@types/follow-redirects": "^1.14.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^24.13.3",
    "@vercel/ncc": "^0.44.1",
    "follow-redirects": "^1.16.0",
    "jest": "^30.4.2",
    "jest-circus": "^30.4.2",
    "js-yaml": "^5.2.1",
    "mock-fs": "^5.5.0",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
